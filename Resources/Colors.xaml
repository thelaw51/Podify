<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Accent -->
    <Color x:Key="Primary">#5B21B6</Color>
    <Color x:Key="PrimaryDark">#8B5CF6</Color>
    <Color x:Key="PrimaryOn">#FFFFFF</Color>

    <!-- Surfaces -->
    <Color x:Key="Background">#FAFAFA</Color>
    <Color x:Key="BackgroundDark">#0B0B12</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#16161F</Color>
    <Color x:Key="SurfaceMuted">#F1F1F4</Color>
    <Color x:Key="SurfaceMutedDark">#1F1F2B</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#11111A</Color>
    <Color x:Key="TextPrimaryDark">#F5F5F7</Color>
    <Color x:Key="TextSecondary">#5C5C68</Color>
    <Color x:Key="TextSecondaryDark">#A0A0B0</Color>
    <Color x:Key="TextMuted">#8C8C99</Color>
    <Color x:Key="TextMutedDark">#6B6B7A</Color>

    <!-- Lines / borders -->
    <Color x:Key="Divider">#E5E5EA</Color>
    <Color x:Key="DividerDark">#2A2A35</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>

    <!-- Legacy keys still referenced by default Styles.xaml -->
    <Color x:Key="Light">#DFD8F7</Color>
    <Color x:Key="Dark">#3B0F8E</Color>
    <Color x:Key="LightGray">#E5E5E1</Color>
    <Color x:Key="MidGray">#969696</Color>
    <Color x:Key="DarkGray">#505050</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

</ResourceDictionary>
