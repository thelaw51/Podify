<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="Podify.Pages.SubscriptionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Podify.ViewModels"
    xmlns:m="clr-namespace:Podify.Models"
    x:DataType="vm:SubscriptionsViewModel"
    Shell.NavBarIsVisible="False">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshAllCommand}">
        <CollectionView ItemsSource="{Binding Subscriptions}" SelectionMode="None"
                        SizeChanged="OnCollectionSizeChanged">
            <CollectionView.ItemsLayout>
                <GridItemsLayout x:Name="AllShowsLayout" Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="40" Spacing="14" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="🎧" FontSize="56" HorizontalOptions="Center" />
                    <Label Style="{StaticResource H1}" Text="No podcasts yet" HorizontalOptions="Center" />
                    <Label Style="{StaticResource Caption}"
                           Text="Browse categories in Discover, search for a show, or import an OPML file from your old app."
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.Header>
                <VerticalStackLayout Spacing="34">

                    <!-- Header -->
                    <Grid Padding="20,16,20,0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Style="{StaticResource Eyebrow}" Text="Library" />
                            <Label Style="{StaticResource Display}" Text="Your Podcasts" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Style="{StaticResource SubtleButton}"
                                Text="Import OPML"
                                VerticalOptions="Center"
                                Command="{Binding ImportOpmlCommand}" />
                    </Grid>

                    <!-- Import progress -->
                    <Border Margin="20,0" Padding="12,10"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMuted}, Dark={StaticResource SurfaceMutedDark}}"
                            IsVisible="{Binding IsImporting}">
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <ActivityIndicator IsRunning="{Binding IsImporting}" HeightRequest="18" WidthRequest="18" />
                            <Label Style="{StaticResource Caption}" Text="{Binding ImportStatus}"
                                   LineBreakMode="TailTruncation" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Continue listening -->
                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasInProgress}">
                        <VerticalStackLayout Margin="20,0" Spacing="2">
                            <Label Style="{StaticResource Eyebrow}" Text="Queue" />
                            <Label Style="{StaticResource H1}" Text="Continue listening" />
                        </VerticalStackLayout>
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Padding="20,0" Spacing="14">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="InProgress" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InProgressItem">
                                        <Border Style="{StaticResource Card}" Padding="12" WidthRequest="240">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SubscriptionsViewModel}}, Path=ResumeCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8"
                                                  ColumnDefinitions="56,*" ColumnSpacing="12">
                                                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                                        Style="{StaticResource ArtworkBorder}" HeightRequest="56"
                                                        WidthRequest="56" VerticalOptions="Start">
                                                    <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill"
                                                           HeightRequest="56" WidthRequest="56" />
                                                </Border>
                                                <Label Grid.Row="0" Grid.Column="1" Style="{StaticResource Caption}"
                                                       Text="{Binding PodcastTitle}" LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                                <Label Grid.Row="1" Grid.Column="1" Style="{StaticResource H2}"
                                                       FontSize="14" Text="{Binding Episode.Title}"
                                                       LineBreakMode="TailTruncation" MaxLines="2" />
                                                <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                             Progress="{Binding ProgressFraction}" />
                                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                      ColumnDefinitions="*,Auto">
                                                    <Label Grid.Column="0" Style="{StaticResource Caption}"
                                                           Text="{Binding TimeLeftLabel}" />
                                                    <Label Grid.Column="1" Style="{StaticResource Caption}"
                                                           Text="▶  Resume"
                                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                           FontFamily="OpenSansSemibold" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Margin="20,0"
                             Color="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DividerDark}}"
                             IsVisible="{Binding HasTodaysEpisodes}" />

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasTodaysEpisodes}">
                        <VerticalStackLayout Margin="20,0" Spacing="2">
                            <Label Style="{StaticResource Eyebrow}" Text="Fresh" />
                            <Label Style="{StaticResource H1}" Text="New today" />
                        </VerticalStackLayout>
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Padding="20,0" Spacing="14">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="TodaysEpisodes" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TodaysEpisodeItem">
                                        <Border Style="{StaticResource Card}" Padding="12" WidthRequest="240">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SubscriptionsViewModel}}, Path=PlayNewEpisodeCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8"
                                                  ColumnDefinitions="56,*" ColumnSpacing="12">
                                                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                                        Style="{StaticResource ArtworkBorder}" HeightRequest="56"
                                                        WidthRequest="56" VerticalOptions="Start">
                                                    <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill"
                                                           HeightRequest="56" WidthRequest="56" />
                                                </Border>
                                                <Label Grid.Row="0" Grid.Column="1" Style="{StaticResource Caption}"
                                                       Text="{Binding PodcastTitle}" LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                                <Label Grid.Row="1" Grid.Column="1" Style="{StaticResource H2}"
                                                       FontSize="14" Text="{Binding Episode.Title}"
                                                       LineBreakMode="TailTruncation" MaxLines="2" />
                                                <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Style="{StaticResource Caption}" Text="{Binding DurationLabel}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Margin="20,0"
                             Color="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DividerDark}}"
                             IsVisible="{Binding HasRecentlyAdded}" />

                    <!-- Recently added carousel -->
                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasRecentlyAdded}">
                        <VerticalStackLayout Margin="20,0" Spacing="2">
                            <Label Style="{StaticResource Eyebrow}" Text="Just added" />
                            <Label Style="{StaticResource H1}" Text="Recently added" />
                        </VerticalStackLayout>
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Padding="20,0" Spacing="14">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="RecentlyAdded" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="m:Podcast">
                                        <Grid WidthRequest="148" RowDefinitions="148,40,18" RowSpacing="6">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SubscriptionsViewModel}}, Path=OpenPodcastCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Border Grid.Row="0" Style="{StaticResource ArtworkBorder}"
                                                    HeightRequest="148" WidthRequest="148">
                                                <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill"
                                                       HeightRequest="148" WidthRequest="148" />
                                            </Border>
                                            <Label Grid.Row="1" Style="{StaticResource H2}" Text="{Binding Title}"
                                                   FontSize="14" LineBreakMode="TailTruncation" MaxLines="2"
                                                   VerticalTextAlignment="Start" />
                                            <Label Grid.Row="2" Style="{StaticResource Caption}"
                                                   Text="{Binding Author}" LineBreakMode="TailTruncation" MaxLines="1"
                                                   VerticalTextAlignment="Start" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Margin="20,0"
                             Color="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DividerDark}}" />

                    <VerticalStackLayout Margin="20,0,20,6" Spacing="2">
                        <Label Style="{StaticResource Eyebrow}" Text="Browse" />
                        <Label Style="{StaticResource H1}" Text="All shows" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Podcast">
                    <Grid HorizontalOptions="Center" WidthRequest="160" RowDefinitions="160,40,18" RowSpacing="6">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SubscriptionsViewModel}}, Path=OpenPodcastCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <Grid Grid.Row="0" HeightRequest="160" WidthRequest="160">
                            <Border Style="{StaticResource ArtworkBorder}" HeightRequest="160" WidthRequest="160">
                                <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill"
                                       HeightRequest="160" WidthRequest="160" />
                            </Border>
                            <Button Text="⋯"
                                    HorizontalOptions="End" VerticalOptions="Start"
                                    Margin="0,6,6,0"
                                    BackgroundColor="#99000000"
                                    TextColor="White"
                                    CornerRadius="14"
                                    WidthRequest="28" HeightRequest="28"
                                    MinimumHeightRequest="28"
                                    Padding="0,-4,0,0"
                                    FontSize="18"
                                    FontFamily="OpenSansSemibold"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SubscriptionsViewModel}}, Path=ShowPodcastMenuCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                        <Label Grid.Row="1" Style="{StaticResource H2}" Text="{Binding Title}" FontSize="14"
                               LineBreakMode="TailTruncation" MaxLines="2" VerticalTextAlignment="Start" />
                        <Label Grid.Row="2" Style="{StaticResource Caption}" Text="{Binding Author}"
                               LineBreakMode="TailTruncation" MaxLines="1" VerticalTextAlignment="Start" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="32" Color="Transparent" />
            </CollectionView.Footer>
        </CollectionView>
    </RefreshView>
</ContentPage>