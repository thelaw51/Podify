<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PodcastApp.Pages.PlayerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:PodcastApp.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="vm:PlayerViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" Padding="20,24,20,32" RowSpacing="20">

        <!-- Header label -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Style="{StaticResource Eyebrow}" Text="Now Playing" />
        </VerticalStackLayout>

        <!-- Artwork hero -->
        <Border Grid.Row="1"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="320"
                MaximumHeightRequest="320"
                Style="{StaticResource ArtworkBorder}"
                IsVisible="{Binding HasArtwork}">
            <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill" />
        </Border>

        <!-- Empty-state placeholder -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="10"
                             IsVisible="{Binding HasArtwork, Converter={StaticResource InverseBool}}">
            <Label Text="🎙️" FontSize="64" HorizontalOptions="Center" />
            <Label Style="{StaticResource Caption}" Text="Pick an episode to start listening" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Title + author -->
        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label Style="{StaticResource H1}"
                   Text="{Binding Current.Title, FallbackValue='Nothing playing'}"
                   HorizontalTextAlignment="Center" LineBreakMode="WordWrap" MaxLines="2" />
        </VerticalStackLayout>

        <!-- Scrub + times -->
        <VerticalStackLayout Grid.Row="3" Spacing="2">
            <Slider x:Name="ScrubSlider"
                    Minimum="0"
                    Maximum="{Binding Duration.TotalSeconds, FallbackValue=1}"
                    Value="{Binding PositionSeconds, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,*">
                <Label Grid.Column="0" Style="{StaticResource Caption}" Text="{Binding Position, StringFormat='{0:hh\\:mm\\:ss}'}" />
                <Label Grid.Column="1" Style="{StaticResource Caption}" Text="{Binding Duration, StringFormat='{0:hh\\:mm\\:ss}'}" HorizontalTextAlignment="End" />
            </Grid>
        </VerticalStackLayout>

        <!-- Transport row -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,Auto,*,*" ColumnSpacing="8" VerticalOptions="Center">
            <Button Grid.Column="0" Style="{StaticResource SubtleButton}"
                    Text="{Binding Speed, StringFormat='{0:0.00}x'}"
                    Command="{Binding CycleSpeedCommand}" />
            <Button Grid.Column="1" Style="{StaticResource IconButton}"
                    Text="−15s"
                    FontSize="14"
                    Command="{Binding SkipBackCommand}" />
            <Button Grid.Column="2" Style="{StaticResource PrimaryPlayButton}"
                    Text="{Binding PlayPauseLabel}"
                    Command="{Binding TogglePlayPauseCommand}" />
            <Button Grid.Column="3" Style="{StaticResource IconButton}"
                    Text="+30s"
                    FontSize="14"
                    Command="{Binding SkipForwardCommand}" />
            <BoxView Grid.Column="4" Color="Transparent" />
        </Grid>

        <toolkit:MediaElement Grid.Row="5" x:Name="Media" IsVisible="False" HeightRequest="0" />
    </Grid>
</ContentPage>
