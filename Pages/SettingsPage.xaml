<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Podify.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Podify.ViewModels"
    x:DataType="vm:SettingsViewModel"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,60" Spacing="28"
                             MaximumWidthRequest="680" HorizontalOptions="Center">

            <!-- Playback -->
            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource Eyebrow}" Text="Playback" />

                <Border Style="{StaticResource Card}" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickSkipForwardCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Style="{StaticResource Body}" Text="Skip forward" VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" Style="{StaticResource Body}" Text="{Binding SkipForwardLabel}"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickSkipBackCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Style="{StaticResource Body}" Text="Skip back" VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" Style="{StaticResource Body}" Text="{Binding SkipBackLabel}"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickDefaultSpeedCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Style="{StaticResource Body}" Text="Default speed" VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" Style="{StaticResource Body}" Text="{Binding DefaultSpeedLabel}"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Listening stats -->
            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource Eyebrow}" Text="Your listening" />
                <Border Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Style="{StaticResource Body}" Text="Total time listened" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Style="{StaticResource Body}" Text="{Binding TotalListeningLabel}"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1"
                                 Color="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DividerDark}}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Style="{StaticResource Body}" Text="Episodes completed" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Style="{StaticResource Body}" Text="{Binding EpisodesCompletedLabel}"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
