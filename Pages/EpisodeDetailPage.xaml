<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Podify.Pages.EpisodeDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Podify.ViewModels"
    xmlns:m="clr-namespace:Podify.Models"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    x:DataType="vm:EpisodeDetailViewModel"
    Title="Episode"
    ios:Page.UseSafeArea="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,12,20,100" Spacing="18">

            <!-- Artwork -->
            <Border Style="{StaticResource ArtworkBorder}"
                    HorizontalOptions="Center"
                    HeightRequest="220" WidthRequest="220">
                <Image Source="{Binding ArtworkUrl}" Aspect="AspectFill" />
            </Border>

            <!-- Eyebrow: podcast title -->
            <Label Style="{StaticResource Eyebrow}"
                   Text="{Binding Podcast.Title}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="TailTruncation" />

            <!-- Episode title -->
            <Label Style="{StaticResource H1}"
                   Text="{Binding Episode.Title}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <!-- Date + duration row -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Style="{StaticResource Caption}"
                       Text="{Binding Episode.Published, StringFormat='{0:MMM d, yyyy}'}" />
                <Label Style="{StaticResource Caption}" Text="·" />
                <Label Style="{StaticResource Caption}"
                       Text="{Binding Episode.Duration, StringFormat='{0:hh\\:mm\\:ss}'}" />
            </HorizontalStackLayout>

            <!-- Transport row -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,4,0,0"
                                   IsVisible="{Binding IsPreview, Converter={StaticResource InverseBool}}">
                <Button Text="▶  Play" Command="{Binding PlayCommand}" />
                <Button Style="{StaticResource SubtleButton}"
                        Text="{Binding QueueLabel}"
                        Command="{Binding ToggleQueueCommand}" />
                <Button Style="{StaticResource SubtleButton}"
                        Text="Download"
                        Command="{Binding DownloadCommand}" />
            </HorizontalStackLayout>

            <!-- Mark played toggle -->
            <Button Style="{StaticResource GhostButton}"
                    Text="{Binding PlayedLabel}"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsPreview, Converter={StaticResource InverseBool}}"
                    Command="{Binding ToggleListenedCommand}" />

            <!-- Preview hint -->
            <Label Style="{StaticResource Caption}"
                   Text="Preview — subscribe to play, queue, or download."
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding IsPreview}" />

            <!-- Chapters -->
            <Border Style="{StaticResource Card}" Padding="16" IsVisible="{Binding HasChapters}">
                <VerticalStackLayout Spacing="10">
                    <Label Style="{StaticResource Eyebrow}" Text="Chapters" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Chapters}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="m:Chapter">
                                <Grid ColumnDefinitions="70,*" Padding="0,8" ColumnSpacing="12">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EpisodeDetailViewModel}}, Path=JumpToChapterCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Style="{StaticResource Caption}"
                                           Text="{Binding Start, StringFormat='{0:h\\:mm\\:ss}'}"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="1" Style="{StaticResource Body}"
                                           Text="{Binding Title}"
                                           LineBreakMode="TailTruncation" MaxLines="2"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Description -->
            <Border Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource Eyebrow}" Text="About this episode" />
                    <Label Style="{StaticResource Body}"
                           Text="{Binding DescriptionText}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
